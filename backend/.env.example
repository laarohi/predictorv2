# Application
# Keep false in production. DEBUG also gates /api/docs exposure and OAuth
# allow_insecure_http; set true only for local development.
DEBUG=false
APP_NAME="Predictor v2"

# Database
DATABASE_URL=postgresql://predictor:predictor@localhost:5432/predictor

# JWT Authentication
# REQUIRED. When DEBUG=false the app refuses to start with a weak/short/default
# value. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"   (or: openssl rand -hex 32)
JWT_SECRET_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Football-Data.org (token for /v4 endpoints)
FOOTBALL_DATA_TOKEN=

# CORS
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:3000

# Tournament config
TOURNAMENT_CONFIG_PATH=../config/worldcup2026.yml
